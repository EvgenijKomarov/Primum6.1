# Example env file for docker-compose
#=======Forbidden for change variables==========
CONFIGSERVICE_URL=http://configservice:5000
DB_HOST=primum-sqlserver
DB_PORT=1433
RABBITMQ_HOST=primum-rabbitmq
RABBITMQ_PORT=5672

#=============Changeable variables==============
DB_PASSWORD=_pASS1234567890
WEBAPI_JWT_SEED=your-super-secret-key-that-should-be-at-least-32-characters-long
WEBAPI_JWT_ISSUER=http://localhost:4200
WEBAPI_JWT_AUDIENCE=http://localhost:4200
WEBAPI_JWT_LIFETIME_MINUTES=360
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
GATEWAY_URL=http://localhost:4200
