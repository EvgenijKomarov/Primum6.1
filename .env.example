# Example env file for docker-compose
# If you are behind a proxy, set these values and then run `docker compose --env-file .env.example up --build`
# Leave empty if not using proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# SQL server SA password (change)
SA_PASSWORD=YourStrong!Passw0rd
