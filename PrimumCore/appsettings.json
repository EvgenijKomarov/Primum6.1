{
  "ConnectionStrings": {
    "DefaultConnection": "Server=KOMAROVE;Database=PrimumDB;Trusted_Connection=true;TrustServerCertificate=True;"
  },
  "Urls": "http://localhost:5000;https://localhost:5001",
  "AllowedHosts": "*",
  "Constants": {
    "BlockedDaysForLessonCreation": 3
  },
  "SwaggerOn": true,
  "RabbitMQ": {
    "IsFake": true,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Queues": [
      {
        "Name": "LessonFailureNotification",
        "Durable": true,
        "Exclusive": false,
        "AutoDelete": false
      },
      {
        "Name": "LessonNotification",
        "Durable": true,
        "Exclusive": false,
        "AutoDelete": false
      },
      {
        "Name": "LessonPreparationNotification",
        "Durable": true,
        "Exclusive": false,
        "AutoDelete": false
      }
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Verbose",
          "outputTemplate": "{Timestamp:yyyy.MM.dd HH:mm:ss zzz} [{Level}]: {Message:l}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../Logs/log.txt",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Verbose",
          "outputTemplate": "{Timestamp:yyyy.MM.dd HH:mm:ss zzz} [{Level}]: {Message:l}{NewLine}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
