{
  "runtime": "Net100",
  "documentGenerator": {
    "fromDocument": {
      "url": "http://localhost:5001/swagger/v1/swagger.json",
      "output": null
    }
  },
  "codeGenerators": {
    "openApiToCSharpClient": {
      "className": "{controller}Client",
      "namespace": "CoreConnection",
      "additionalNamespaceUsages": [
        "CoreConnection.DTOs",
        "CoreConnection.DTOs.Inputs"
      ],
      "generateDtoTypes": true, // Генерируем DTO
      "dtoTypesNamespace": "CoreConnection.DTOs",
      "excludedTypeNames": [
        "AbonementDto",
        "AdminProfileDto",
        "AbonementSheduleDto",
        "CourseDto",
        "CourseThemeDto",
        "AdminProfileDto",
        "IncidentDto",
        "IncidentLogDto",
        "LessonDto",
        "PromocodeDto",
        "StudentProfileDto",
        "TeacherProfileDto",
        "TeacherSheduleDto",
        "UserDto",
        "UserDtoLite",
        "CourseInputDto",
        "CourseThemeInputDto",
        "GradingInputDto",
        "IncidentDecisionInputDto",
        "LoggingInputDto",
        "PromocodeInputDto",
        "RegistrationInputDto",
        "TeacherSheduleInputDto",
        "IncidentMeaning",
        "IncidentDecision",
        "AbonementStatus",
        "ApproveStatus",
        "Grading",
        "IncidentStatus",
        "LessonStatus",
        "Permission",
        "TokenMeaning",
        "DayOfWeek",
        "TeacherRankDto",
        "StudentRankDto",
        "CourseRankDto",
        "LessonsByDateDto",
        "FutureLessonDto",
        "CourseDtoLite"
      ],
      "generateNullableReferenceTypes": true, // Учитывать C# 11 required / nullable
      "generateRequiredProperties": true, // Генерировать модификатор 'required' в клиенте (если целевая версия .NET поддерживает)
      "schemaNameGenerator": "Default", // Default превратит PageResult<User> в PageResultOfUser
      "arrayType": "System.Collections.Generic.List", // IEnumerable -> List
      "arrayInstanceType": "System.Collections.Generic.List",
      "generateClientClasses": true,
      "generateClientInterfaces": false,
      "generateOptionalParameters": true,
      "useBaseUrl": true,
      "injectHttpClient": true,
      "disposeHttpClient": false,
      "operationGenerationMode": "MultipleClientsFromFirstTagAndPathSegments",
      "output": "CoreClients.cs"
    }
  }
}